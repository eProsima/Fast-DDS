names:
    fastdds:
        cmake-args:
            - -DBUILD_TESTING=ON
            - -DCMAKE_COMPILE_WARNING_AS_ERROR=ON
            - -DFASTDDS_PIM_API_TESTS=ON
            - -DFASTDDS_STATISTICS=ON
            - -DFASTDDS_UNIT_TESTS=OFF
            - -DNO_TLS=OFF
            - -DPERFORMANCE_TESTS=ON
            - -DRTPS_API_TESTS=ON
            - -DSECURITY=ON
            - -DSANITIZER=Address
    discovery-server:
        cmake-args:
            - -DSANITIZER=Address
    googletest-distribution:
        cmake-args:
            - -Dgtest_force_shared_crt=ON
            - -DBUILD_SHARED_LIBS=ON
            - -DBUILD_GMOCK=ON
