names:
    bzip2:
        cmake-args:
            - -DENABLE_LIB_ONLY=ON
            - -DENABLE_DOCS=OFF
    foonathan_memory_vendor:
        cmake-args:
            - -DBUILD_MEMORY_TOOLS=OFF
    fastdds:
        cmake-args:
            - -DBUILD_TESTING=OFF
            - -DBUILD_DOCUMENTATION=OFF
            - -DBZIP2_REQUIRED=ON
            - -DCMAKE_COMPILE_WARNING_AS_ERROR=ON
            - -DCOMPILE_EXAMPLES=ON
            - -DCOMPILE_TOOLS=ON
            - -DFASTDDS_ENFORCE_LOG_INFO=ON
            - -DENABLE_OLD_LOG_MACROS=OFF
            - -DINSTALL_EXAMPLES=ON
            - -DINSTALL_TOOLS=ON
            - -DINTERNAL_DEBUG=ON
            - -DNO_TLS=OFF
            - -DSHM_TRANSPORT_DEFAULT=ON
            - -DSTRICT_REALTIME=OFF
            - -DZLIB_REQUIRED=ON
