<?xml version="1.0" encoding="UTF-8"?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <transport_descriptors>
        <transport_descriptor>
            <transport_id>client_tcp_transport</transport_id>
            <type>TCPv4</type>
            <keep_alive_frequency_ms>3000</keep_alive_frequency_ms>
            <keep_alive_timeout_ms>10000</keep_alive_timeout_ms>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="initial_peer" is_default_profile="true">
        <rtps>
            <!-- Disable builtin transports and use custom transports -->
            <useBuiltinTransports>false</useBuiltinTransports>
            <userTransports>
                <transport_id>client_tcp_transport</transport_id>
            </userTransports>

            <builtin>
                <initialPeersList>
                    <locator>
                        <tcpv4>
                            <physical_port>12345</physical_port>
                            <address>172.28.16.200</address>
                        </tcpv4>
                    </locator>
                </initialPeersList>
                <discovery_config>
                    <discoveryProtocol>SIMPLE</discoveryProtocol>
                </discovery_config>
            </builtin>
        </rtps>
    </participant>
</profiles>
