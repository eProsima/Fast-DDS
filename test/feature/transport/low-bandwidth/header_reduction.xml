<?xml version="1.0" encoding="utf-8"  ?>
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastdds_profiles" >
    <profiles>
        <transport_descriptors>
            <transport_descriptor>
                <transport_id>udp_transport</transport_id>
                <type>UDPv4</type>
            </transport_descriptor>
            <transport_descriptor>
                <transport_id>reduction_transport</transport_id>
                <type>HEADER_REDUCTION</type>
                <low_level_transport>udp_transport</low_level_transport>
            </transport_descriptor>
        </transport_descriptors>
        <participant profile_name="ParticipantTest">
            <rtps>
                <propertiesPolicy>
                    <properties>
                        <property>
                            <name>rtps.header_reduction.remove_version</name>
                            <value>true</value>
                        </property>
                        <property>
                            <name>rtps.header_reduction.remove_vendor_id</name>
                            <value>true</value>
                        </property>
                        <property>
                            <name>rtps.header_reduction.submessage.combine_id_and_flags</name>
                            <value>true</value>
                        </property>
                        <property>
                            <name>rtps.header_reduction.submessage.compress_entitiy_ids</name>
                            <value>16,16</value>
                        </property>
                    </properties>
                </propertiesPolicy>
                <userTransports>
                    <transport_id>reduction_transport</transport_id>
                </userTransports>
                <useBuiltinTransports>false</useBuiltinTransports>
            </rtps>
        </participant>
    </profiles>
</dds>
